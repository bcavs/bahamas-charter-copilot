# Copy to .env.local and fill in to enable AI extraction and drafting.
# Without a key, the app falls back to the deterministic rules engine.

# Anthropic API key (https://console.anthropic.com)
ANTHROPIC_API_KEY=

# Optional: override the model used for extraction/drafting.
# Defaults to claude-opus-4-8. For lower cost/latency, try claude-haiku-4-5.
# ANTHROPIC_MODEL=claude-opus-4-8
